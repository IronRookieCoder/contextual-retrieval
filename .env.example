# DeepSeek API（上下文生成）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Jina AI API（嵌入 + 重排序）
JINA_API_KEY=your_jina_api_key_here

# 向后兼容（可选）
ANTHROPIC_API_KEY=your_deepseek_api_key_here
VOYAGE_API_KEY=your_jina_api_key_here
COHERE_API_KEY=your_jina_api_key_here

# Elasticsearch（可选）
ELASTICSEARCH_URL=http://localhost:9200

# 模型配置（可选）
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
JINA_EMBEDDING_MODEL=jina-embeddings-v4
JINA_RERANKER_MODEL=jina-reranker-v3

# 处理参数（可选）
EMBEDDING_BATCH_SIZE=128
MAX_PARALLEL_THREADS=5
DEFAULT_K=20

# 混合搜索权重（可选）
SEMANTIC_WEIGHT=0.8
BM25_WEIGHT=0.2

# 目录配置（可选）
DATA_DIR=./data
VECTOR_DB_DIR=./data/vector_dbs

# 日志配置（可选）
LOG_LEVEL=INFO

# 重试配置（可选）
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=60.0
